                "AXIOM_BUILD_PHYSICS_MODULE": "OFF",
                "AXIOM_BUILD_SCRIPTING_MODULE": "OFF",
                "AXIOM_WINDOW_BACKEND_GLFW": "ON",
                "AXIOM_WINDOW_BACKEND_SDL2": "OFF",
                "AXIOM_GRAPHICS_OPENGL": "ON",
                "AXIOM_GRAPHICS_VULKAN": "OFF",
